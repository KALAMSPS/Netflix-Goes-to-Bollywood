# This .gitignore file should be placed at the root of your Unity project

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/
MemoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is ignored
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta
!/[Pp]rojectSettings/**/*.meta

# Visual Studio / Rider
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS generated files
.DS_Store
Thumbs.db

# Crash reports
sysinfo.txt

# Auto-generated files
*.apk
*.aab
*.app
*.exe
*.ipa

# Addressables
ServerData/

# StreamingAssets generated content (optional)
Assets/StreamingAssets/aa.meta
Assets/StreamingAssets/aa/

# Gradle
.gradle/

# Unity Cache
Library/